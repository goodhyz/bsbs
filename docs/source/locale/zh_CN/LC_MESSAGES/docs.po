#: ../../source/guide/DS_BL/CEC2013LSGO.md:13
msgid "Two types of overlapping functions:"
msgstr "两种重叠函数："

#: ../../source/guide/DS_BL/CEC2013LSGO.md:14
msgid "Overlapping functions with conforming subcomponents (F12-F13)"
msgstr "具有符合子组件的重叠函数（F12-F13）"

