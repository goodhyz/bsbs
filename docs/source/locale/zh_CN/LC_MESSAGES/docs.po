msgstr "**\"easy\"**: 训练:[1,2,3,4,5,6] 测试:[7,8,9,10]"

#: ../../source/guide/DS_BL/WCCI2020.md:14
msgid "**\"difficult\"**:  train:[7,8,9,10] test:[1,2,3,4,5,6]"
msgstr "**\"difficult\"**: 训练:[7,8,9,10] 测试:[1,2,3,4,5,6]"

